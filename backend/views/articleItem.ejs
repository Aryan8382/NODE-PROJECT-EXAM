<%- include('navbar') %>

<main class="main-content">
    <div class="container">
        <div class="content-wrapper">
            <div style="margin-bottom: 2rem;">
                <h1 style="font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; line-height: 1.2;">
                    <%= article.title %>
                </h1>
                <div class="article-meta" style="margin-bottom: 2rem;">
                    <span class="article-author">By <%= article.author.username %></span>
                    <span><%= new Date(article.createdAt).toLocaleDateString() %></span>
                    <% if (new Date(article.updatedAt).toLocaleDateString() !== new Date(article.createdAt).toLocaleDateString()) { %>
                        <span>Updated <%= new Date(article.updatedAt).toLocaleDateString() %></span>
                    <% } %>
                </div>
                
                <% if (user && (user._id.toString() === article.author._id.toString() || user.role === 'admin')) { %>
                    <div class="article-actions" style="margin-bottom: 2rem;">
                        <a href="/articles/<%= article._id %>/edit" class="btn btn-secondary">Edit Article</a>
                        <form action="/api/articles/<%= article._id %>" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this article?');">
                            <input type="hidden" name="_method" value="DELETE">
                            <button type="submit" class="btn btn-danger">Delete Article</button>
                        </form>
                    </div>
                <% } %>
            </div>
            
            <div class="article-content" style="font-size: 1.125rem; line-height: 1.8; white-space: pre-wrap;">
                <%= article.content %>
            </div>
            
            <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border-color);">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <strong>Written by <%= article.author.username %></strong>
                        <% if (article.author.role === 'admin') { %>
                            <span style="background: #000000; color: white; padding: 0.25rem 0.75rem; border-radius: 1rem; font-size: 0.75rem; margin-left: 0.5rem;">Admin</span>
                        <% } %>
                    </div>
                    <div style="color: var(--text-light); font-size: 0.875rem;">
                        <%= new Date(article.createdAt).toLocaleDateString('en-US', { 
                            year: 'numeric', 
                            month: 'long', 
                            day: 'numeric' 
                        }) %>
                    </div>
                </div>
            </div>
            
            <div style="margin-top: 2rem; text-align: center;">
                <a href="/" class="btn btn-secondary">← Back to All Articles</a>
                <% if (user) { %>
                    <a href="/my-articles" class="btn btn-primary">My Articles</a>
                <% } %>
            </div>
        </div>
    </div>
</main>

<%- include('footer') %>
